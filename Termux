# PADROES DE VELA
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
def detectar_padroes(candles):
    r = {"bear": [], "bull": []}
    if len(candles) < 3: return r
    c0, c1, c2 = candles[-1], candles[-2], candles[-3]
    corpo = abs(c0["close"] - c0["open"])
    sup   = c0["high"] - max(c0["open"], c0["close"])
    sdn   = min(c0["open"], c0["close"]) - c0["low"]
    rng   = c0["high"] - c0["low"] or 0.0001
    if corpo / rng < 0.1:
        r["bear"].append("Doji"); r["bull"].append("Doji")
    if corpo > 0 and sup > corpo * 2:
        r["bear"].append("Shooting Star")
    if corpo > 0 and sdn > corpo * 2:
        r["bull"].append("Hammer")
    if (c0["close"] < c0["open"] and c1["close"] > c1["open"] and
            c0["open"] >= c1["close"] and c0["close"] <= c1["open"]):
        r["bear"].append("Bearish Engulfing")
    if (c0["close"] > c0["open"] and c1["close"] < c1["open"] and
            c0["open"] <= c1["close"] and c0["close"] >= c1["open"]):
        r["bull"].append("Bullish Engulfing")
    if all(c["close"] < c["open"] for c in [c0,c1,c2]):
        r["bear"].append("3 Vermelhas")
    if all(c["close"] > c["open"] for c in [c0,c1,c2]):
        r["bull"].append("3 Verdes")
    return r


# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# MOTOR DE CONFLUENCIAS
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
def analisar(preco, candles):
    if len(candles) < 30: return None, 0, []
    n   = len(candles)
    obs = detectar_obs(candles)
    pat = detectar_padroes(candles)
    rv  = calc_rsi(candles)
    sk  = calc_stoch(candles)
    ltb, ltb_inc = linha_tendencia(pivot_highs(candles), n)
    lta, lta_inc = linha_tendencia(pivot_lows(candles),  n)
    sv, sc = 0, 0
    rl, cl = [], []
    if em_ob(preco, obs["bear"]): sv += 2; rl.append("OB Bearish")
    if em_ob(preco, obs["bull"]): sc += 2; cl.append("OB Bullish")
    if ltb_inc and ltb_inc < 0 and tocando(preco, ltb):
        sv += 2; rl.append(f"LTB {ltb:.1f}")
    if lta_inc and lta_inc > 0 and tocando(preco, lta):
        sc += 2; cl.append(f"LTA {lta:.1f}")
    if rv >= 70: sv += 1; rl.append(f"RSI {rv}")
    elif rv <= 30: sc += 1; cl.append(f"RSI {rv}")
    if sk >= 80: sv += 1; rl.append(f"Stoch {sk}")
    elif sk <= 20: sc += 1; cl.append(f"Stoch {sk}")
    for p in pat["bear"]: sv += 1; rl.append(p)
    for p in pat["bull"]: sc += 1; cl.append(p)
    if sv >= MIN_SCORE and sv > sc: return "vender",  sv, rl
    if sc >= MIN_SCORE and sc > sv: return "comprar", sc, cl
    return None, max(sv, sc), []


