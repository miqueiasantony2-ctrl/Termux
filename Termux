# EXECUCAO DA ORDEM
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
def executar_ordem(xsrf_token, direcao, preco):
    direction     = 1 if direcao == "comprar" else 2
    token_decoded = unquote(xsrf_token)
    headers = {
        "User-Agent":   "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36",
        "Accept":       "application/json, text/plain, */*",
        "Content-Type": "application/json",
        "Origin":       "https://vexinvest.com",
        "Referer":      "https://vexinvest.com/traderoom",
        "X-Xsrf-Token": token_decoded,
    }
    cookies = {"XSRF-TOKEN": xsrf_token}
    payload = {
        "__token":          token_decoded,
        "amount":           AMOUNT,
        "direction":        direction,
        "expiration":       EXPIRATION,
        "selected_account": ACCOUNT_ID,
        "symbol":           "BTCUSDT",
        "symbol_price":     int(preco),
    }
    try:
        r = requests.post(
            "https://vexinvest.com/publicapi/binary/transaction",
            headers=headers, cookies=cookies, json=payload, timeout=6)
        if r.status_code == 200:
            data = r.json()
            if data.get("status") == "success" or "id" in str(data):
                return True, f"ORDEM {direcao.upper()} EXECUTADA!"
            return False, f"RESPOSTA: {str(data)[:60]}"
        elif r.status_code == 401:
            return False, "TOKEN EXPIRADO! Atualize."
        return False, f"ERRO HTTP {r.status_code}"
    except Exception as e:
        return False, f"ERRO: {str(e)[:50]}"


