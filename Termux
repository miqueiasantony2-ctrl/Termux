# ORDER BLOCKS
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
def detectar_obs(candles):
    bull, bear = [], []
    for i in range(2, len(candles) - 5):
        c   = candles[i]
        fut = candles[i+1:i+6]
        fmax = max(x["high"] for x in fut)
        fmin = min(x["low"]  for x in fut)
        if c["close"] < c["open"]:
            move = (fmax - c["high"]) / c["high"]
            if move > 0.003:
                bull.append({"topo": c["open"], "fundo": c["close"]})
        if c["close"] > c["open"]:
            move = (c["low"] - fmin) / c["low"]
            if move > 0.003:
                bear.append({"topo": c["close"], "fundo": c["open"]})
    return {"bull": bull[-4:], "bear": bear[-4:]}


def em_ob(preco, obs, tol=0.001):
    for ob in obs:
        if ob["fundo"] * (1-tol) <= preco <= ob["topo"] * (1+tol):
            return True
    return False


