# LOOP PRINCIPAL
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
def rodar(xsrf_token):
    ops       = 0
    macro     = []
    ult_min   = -1

    print(f"\n{NEGRITO}{VERDE}{'='*50}{RESET}")
    print(f"{NEGRITO}{VERDE}  BOT SNIPER VEX - INICIADO{RESET}")
    print(f"{NEGRITO}{VERDE}{'='*50}{RESET}")
    log(f"Simbolo: {SYMBOL} | Max ops/dia: {MAX_OPS_DIA}", AZUL)
    log(f"Confluencias minimas: {MIN_SCORE} | Intervalo: {INTERVALO}s", AZUL)
    print()

    while True:
        try:
            if ops >= MAX_OPS_DIA:
                log(f"LIMITE DIARIO ATINGIDO ({MAX_OPS_DIA} ops). Aguardando amanha...", AMARELO)
                time.sleep(3600)
                continue

            preco = pegar_preco()
            if not preco:
                log("Sem preco. Tentando novamente...", AMARELO)
                time.sleep(INTERVALO)
                continue

            # Macro - 1 ponto por minuto
            m = datetime.now().minute
            if m != ult_min:
                macro.append(preco)
                if len(macro) > 60: macro.pop(0)
                ult_min = m
                log(f"MACRO: {preco:,.2f} | {len(macro)}/60min coletados", AZUL)

            candles = pegar_candles(120)
            if not candles:
                time.sleep(INTERVALO)
                continue

            rv = calc_rsi(candles)
            sk = calc_stoch(candles)
            sinal, score, razoes = analisar(preco, candles)

            # Status a cada ciclo
            status = f"Preco: {preco:,.2f} | RSI: {rv} | Stoch: {sk} | Score: {score} | Ops: {ops}/{MAX_OPS_DIA}"
            print(f"\r{AZUL}{status}{RESET}", end="", flush=True)

            if sinal:
                print()  # quebra linha do status
                cor = VERM if sinal == "vender" else VERDE
                log(f"SINAL: {sinal.upper()} | Score: {score} | {' | '.join(razoes)}", cor)

                ok, msg = executar_ordem(xsrf_token, sinal, preco)

                if ok:
                    ops += 1
                    log(f"{msg} | Total hoje: {ops}/{MAX_OPS_DIA}", VERDE)
                else:
                    log(msg, VERM)
                    if "expirado" in msg.lower():
                        log("Bot pausado. Atualize o token e reinicie.", VERM)
                        break

            time.sleep(INTERVALO)

        except KeyboardInterrupt:
            print()
            log("Bot encerrado pelo usuario.", AMARELO)
            break
        except Exception as e:
            log(f"Erro: {str(e)[:60]}", VERM)
            time.sleep(10)


